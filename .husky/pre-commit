# 신발 또는 마라톤 대회 데이터가 변경된 경우 검증 실행
# (마라톤은 status/개최일 일관성 검사 — 종료된 대회가 '접수중'으로 남는 것을 막는다)
SHOE_FILES=$(git diff --cached --name-only | grep -E "src/lib/data/(shoes|marathon)/")

if [ -n "$SHOE_FILES" ]; then
  echo "🔍 데이터 변경 감지 — 무결성 검증 실행..."
  node scripts/validate.js
  if [ $? -ne 0 ]; then
    echo "❌ 데이터 검증 실패. 에러를 수정 후 다시 커밋하세요."
    exit 1
  fi
fi
